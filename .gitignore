# ==========================================
# JJPlayer - Git 忽略规则配置 (.gitignore)
# ==========================================

# ------------------------------------------
# macOS 系统临时文件
# ------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
Icon\r
._*
.DocumentRevisions-V100
.SyncID
.SyncState
.Spotlight-V100
.FolderActionsLifeline
.Trash
.VolumeIcon.icns
.com.apple.timemachine.donotpresent
.temporary
.inherited-configuration

# ------------------------------------------
# Xcode 个人配置与缓存文件 (保留工程文件，忽略个人专属配置)
# ------------------------------------------
# 忽略 Xcode 的个人用户数据、状态与布局缓存
*.username
*.xcuserstate
*.xcuserdatad
xcuserdata/
MostRecentWindowPosition

# 忽略 DerivedData (派生数据/编译缓存)
DerivedData/

# 忽略 Xcode 自动生成的构建产物与日志
build/
*.xcresult
*.moved-aside
*.ipa
*.dSYM.zip
*.dSYM
*.log

# ------------------------------------------
# Swift Package Manager (SPM) 临时文件
# ------------------------------------------
# 忽略 SPM 本地编译缓存
.build/

# 如果你希望锁定 SPM 依赖版本，请提交 Package.resolved。
# 如果不希望提交版本锁定文件，可取消注释下方这行：
# Package.resolved

# ------------------------------------------
# Carthage 与 CocoaPods (如后续引入)
# ------------------------------------------
# Carthage 编译产物
Carthage/Build/

# CocoaPods 依赖库 (Pods 目录由 Podfile 管理，无需提交)
Pods/
# Podfile.lock 建议提交以保证团队版本一致，不忽略
# !Podfile.lock

# ------------------------------------------
# 静态分析与诊断工具缓存
# ------------------------------------------
# SwiftLint 缓存目录
.swiftlint/
.swiftlint-cache/

# ------------------------------------------
# 编辑器与 IDE 临时文件 (VSCode, JetBrains 等)
# ------------------------------------------
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*~

# ------------------------------------------
# 格式大师发布与分发目录
# ------------------------------------------
ipa/
